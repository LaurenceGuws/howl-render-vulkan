{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "zig: build",
      "type": "shell",
      "command": "zig build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "zig: test (all)",
      "type": "shell",
      "command": "zig build test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "zig: test (filter)",
      "type": "shell",
      "command": "zig build test -- --test-filter \"${input:testFilter}\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "testFilter",
      "type": "promptString",
      "description": "Substring to match a Zig test name"
    }
  ]
}
